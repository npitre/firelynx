#!/bin/bash

# Firelynx - Accessible Web Browser
# Firefox backend with lynx frontend for modern web accessibility

# Get the directory where this script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Check for src/main.py in the same directory first (for running from package directory)
if [[ -f "$SCRIPT_DIR/src/main.py" ]]; then
    FIRELYNX_PATH="$SCRIPT_DIR"
    echo "Running from package directory: $SCRIPT_DIR"
else
    # Fall back to installed location
    FIRELYNX_PATH="$HOME/.local/share/firelynx"

    if [[ -d "$FIRELYNX_PATH" ]] && [[ -f "$FIRELYNX_PATH/src/main.py" ]]; then
        echo "Using installed location: $FIRELYNX_PATH"
    else
        echo "Error: Firelynx is not installed properly."
        echo "Please ensure either:"
        echo "  - src/main.py exists in current directory, or"
        echo "  - Firelynx is properly installed with './install.sh'"
        exit 1
    fi
fi

# Selenium 4.x manages geckodriver automatically via its bundled selenium-manager
# (a standalone command on some distros, an embedded module on others). If a
# standalone command is present, pre-warm the driver cache; otherwise Selenium
# fetches the driver on demand from Python, so there is nothing to do here.
if command -v selenium-manager >/dev/null 2>&1; then
    selenium-manager --browser firefox --output JSON >/dev/null 2>&1 || true
fi

# Set up Python path to include the package directory
export PYTHONPATH="$FIRELYNX_PATH:$PYTHONPATH"

# Launch Firelynx
python3 "$FIRELYNX_PATH/src/main.py" "$@"
